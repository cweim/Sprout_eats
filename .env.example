# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (for photo storage - only needed for SQLite migration)
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Cloud API Key (enable Places API and Maps Static API)
GOOGLE_API_KEY=your_google_api_key_here

# Whisper model size: tiny, base, small, medium, large
# Smaller = faster but less accurate, larger = slower but more accurate
WHISPER_MODEL=base

# Supabase Configuration (get from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Local browser testing only.
# In production, keep LOCAL_DEV_AUTH=false so Telegram initData is required.
LOCAL_DEV_AUTH=false
DEV_TELEGRAM_USER_ID=your_numeric_telegram_user_id_here

# Database path (SQLite - legacy, only needed for migration)
DATABASE_PATH=discovery_bot.db

# Mini App URL (for the interactive viewer)
# For local dev: use ngrok to expose localhost, e.g., https://abc123.ngrok.io
# For production: deploy API server and set the URL here
WEBAPP_URL=
